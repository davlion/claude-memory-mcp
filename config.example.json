{
  "vms": [
    {
      "name": "dev-vm",
      "host": "dev-vm.local",
      "user": "youruser",
      "ssh_key": "~/.ssh/claude_memory_ed25519",
      "memory_paths": [
        "~/.claude/projects/-home-youruser-src-myproject/memory",
        "~/.claude/projects/-home-youruser-src-other/memory"
      ]
    },
    {
      "name": "build-vm",
      "host": "192.168.1.50",
      "user": "youruser",
      "ssh_key": "~/.ssh/claude_memory_ed25519",
      "memory_paths": [
        "~/.claude/projects/-home-youruser-src-firmware/memory"
      ]
    }
  ],
  "local_cache": "~/.claude-memories",
  "sync_interval_minutes": 5
}
